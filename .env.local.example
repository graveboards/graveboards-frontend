# Frontend environment configuration
# Copy this to .env.local for local development overrides

# Public API URL (browser)
NEXT_PUBLIC_API_URL=/api/v1

# Backend API URL (server-side)
INTERNAL_API_URL=http://localhost:8000/api/v1

# Session signing key
SESSION_SECRET=YOUR-SESSION-SECRET-HERE-MUST-BE-32-CHARS-MIN
